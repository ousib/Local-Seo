# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Paddle Configuration
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENVIRONMENT=sandbox
# Base Plans
VITE_PADDLE_PRICE_ID_STARTER=
VITE_PADDLE_PRICE_ID_PRO=
VITE_PADDLE_PRICE_ID_AGENCY=
# Cycle Specific (Optional - falls back to base if not set)
VITE_PADDLE_PRICE_ID_STARTER_MONTHLY=
VITE_PADDLE_PRICE_ID_STARTER_QUARTERLY=
VITE_PADDLE_PRICE_ID_STARTER_BIANNUAL=
VITE_PADDLE_PRICE_ID_STARTER_YEARLY=
VITE_PADDLE_PRICE_ID_PRO_MONTHLY=
VITE_PADDLE_PRICE_ID_PRO_QUARTERLY=
VITE_PADDLE_PRICE_ID_PRO_BIANNUAL=
VITE_PADDLE_PRICE_ID_PRO_YEARLY=
VITE_PADDLE_PRICE_ID_AGENCY_MONTHLY=
VITE_PADDLE_PRICE_ID_AGENCY_QUARTERLY=
VITE_PADDLE_PRICE_ID_AGENCY_BIANNUAL=
VITE_PADDLE_PRICE_ID_AGENCY_YEARLY=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Contact Form SMTP (Optional for notification)
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
CONTACT_RECIPIENT=gomgomtechnologies@gmail.com
